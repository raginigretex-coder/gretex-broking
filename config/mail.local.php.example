<?php
/**
 * Local SMTP overrides for development only.
 *
 * 1) Copy to `config/mail.local.php`
 * 2) Fill in values
 * 3) DO NOT commit `config/mail.local.php`
 */

// Example:

define('ENQUIRY_NOTIFY_EMAIL', 'info@gretexindustries.com');

define('MAIL_SMTP_HOST', 'smtp.hostinger.com');
define('MAIL_SMTP_PORT', 587);
define('MAIL_SMTP_SECURE', 'tls'); // 'tls' or 'ssl'
define('MAIL_SMTP_USER', 'info@gretexindustries.com');
define('MAIL_SMTP_PASS', 'YOUR_SMTP_PASSWORD_HERE');

define('MAIL_FROM_EMAIL', 'info@gretexindustries.com');
define('MAIL_FROM_NAME', 'Gretex Broking');

// Optional:
// define('MAIL_DEBUG', true);

